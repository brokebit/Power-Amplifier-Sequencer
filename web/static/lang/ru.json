  "config.section_fault_desc": "\u041f\u0440\u0435\u0434\u0435\u043b\u044b, \u043f\u0440\u0438 \u043f\u0440\u0435\u0432\u044b\u0448\u0435\u043d\u0438\u0438 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 PA \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043e\u0442\u043a\u043b\u044e\u0447\u0430\u0435\u0442\u0441\u044f. \u041f\u0440\u0438 \u043f\u0440\u0435\u0432\u044b\u0448\u0435\u043d\u0438\u0438 \u043f\u043e\u0440\u043e\u0433\u0430 \u0441\u0435\u043a\u0432\u0435\u043d\u0441\u0435\u0440 \u043f\u0435\u0440\u0435\u0445\u043e\u0434\u0438\u0442 \u0432 \u0430\u0432\u0430\u0440\u0438\u0439\u043d\u043e\u0435 \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0438 \u043e\u0442\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0440\u0435\u043b\u0435 PA.",
  "config.section_pa": "\u0423\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 PA",
  "config.section_pa_desc": "\u041e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u043a\u0430\u043a\u043e\u0435 \u0440\u0435\u043b\u0435 \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0443\u0441\u0438\u043b\u0438\u0442\u0435\u043b\u0435\u043c \u043c\u043e\u0449\u043d\u043e\u0441\u0442\u0438. \u0421\u0435\u043a\u0432\u0435\u043d\u0441\u0435\u0440 \u043e\u0442\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u044d\u0442\u043e \u0440\u0435\u043b\u0435 \u043f\u0440\u0438 \u0430\u0432\u0430\u0440\u0438\u0438.",
  "config.section_power": "\u041a\u0430\u043b\u0438\u0431\u0440\u043e\u0432\u043a\u0430 \u043c\u043e\u0449\u043d\u043e\u0441\u0442\u0438",
  "config.section_power_desc": "\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u043b\u043e\u0433\u0430\u0440\u0438\u0444\u043c\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0434\u0435\u0442\u0435\u043a\u0442\u043e\u0440\u0430 \u043c\u043e\u0449\u043d\u043e\u0441\u0442\u0438 \u043d\u0430 \u043a\u0430\u0436\u0434\u043e\u043c \u043f\u043e\u0440\u0442\u0443 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u043d\u043e\u0433\u043e \u043e\u0442\u0432\u0435\u0442\u0432\u0438\u0442\u0435\u043b\u044f. \u0414\u0435\u0442\u0435\u043a\u0442\u043e\u0440 \u0432\u044b\u0434\u0430\u0451\u0442 \u043d\u0430\u043f\u0440\u044f\u0436\u0435\u043d\u0438\u0435, \u043f\u0440\u043e\u043f\u043e\u0440\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0435 dBm.",
  "config.section_divider": "\u0414\u0435\u043b\u0438\u0442\u0435\u043b\u044c \u0410\u0426\u041f",
  "config.section_divider_desc": "\u0421\u043e\u043f\u0440\u043e\u0442\u0438\u0432\u043b\u0435\u043d\u0438\u044f \u0440\u0435\u0437\u0438\u0441\u0442\u0438\u0432\u043d\u043e\u0433\u043e \u0434\u0435\u043b\u0438\u0442\u0435\u043b\u044f \u043d\u0430 \u043a\u0430\u0436\u0434\u043e\u043c \u0432\u0445\u043e\u0434\u0435 \u0410\u0426\u041f. \u041f\u0440\u043e\u0448\u0438\u0432\u043a\u0430 \u0432\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u043d\u0430\u043f\u0440\u044f\u0436\u0435\u043d\u0438\u0435 \u0434\u043e \u0434\u0435\u043b\u0438\u0442\u0435\u043b\u044f. \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0435 \u043e\u0431\u0430 \u0432 0 \u0434\u043b\u044f \u043e\u0442\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f \u043a\u043e\u0440\u0440\u0435\u043a\u0446\u0438\u0438.",
  "config.section_therm": "\u041a\u0430\u043b\u0438\u0431\u0440\u043e\u0432\u043a\u0430 \u0442\u0435\u0440\u043c\u0438\u0441\u0442\u043e\u0440\u0430",
  "config.section_therm_desc": "\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b NTC-\u0442\u0435\u0440\u043c\u0438\u0441\u0442\u043e\u0440\u0430 (\u0443\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435 \u0428\u0442\u0435\u0439\u043d\u0445\u0430\u0440\u0442\u0430\u2013\u0425\u0430\u0440\u0442\u0430). \u0421\u0445\u0435\u043c\u0430: VCC \u2192 R Series \u2192 NTC \u2192 GND, \u0410\u0426\u041f \u0438\u0437\u043c\u0435\u0440\u044f\u0435\u0442 \u043d\u0430\u043f\u0440\u044f\u0436\u0435\u043d\u0438\u0435 \u043d\u0430 NTC.",
